  "name": "study-anything-platform-bundle",
  "platforms": [
    "codex",
    "kimi",
    "workbuddy"
  ],
  "privacy_contract": {
    "must_not_log_or_share": [
      "raw source text",
      "learner answers",
      "grading feedback",
      "generated insights",
      "agent endpoints",
      "agent metadata",
      "API keys or model secrets",
      "raw user ids",
      "browser/video/app private context"
