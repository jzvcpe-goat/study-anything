{
  "info": {
    "description": "Minimal public tool contract for Codex, Kimi, WorkBuddy-style agents, and private agent workspaces that call Study Anything as a local-first learning engine.",
    "title": "Study Anything Platform Agent Tools",
    "version": "study-anything-platform-tools-v1"
  },
  "openapi": "3.1.0",
  "paths": {
    "/v1/context-packages/validate": {
      "post": {
        "description": "Validate a Learning Context Package built by a platform Agent before importing web, document, video, app, Markdown, or Obsidian context into Study Anything.",
        "operationId": "study_anything_validate_context_package",
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "additionalProperties": false,
                "properties": {
                  "package": {
                    "additionalProperties": true,
                    "description": "learning-context-package-v1 JSON. It may include bounded source excerpts, but must not include Agent credentials or API keys.",
                    "type": "object"
                  }
                },
                "required": [
                  "package"
                ],
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            },
            "description": "Study Anything tool response. See docs/api.md for endpoint-specific response details."
          },
          "400": {
            "description": "Bad request"
          },
          "404": {
            "description": "Session or resource not found"
          },
          "409": {
            "description": "Workflow state conflict"
          },
          "503": {
            "description": "Optional dependency unavailable"
          }
        },
        "summary": "Validate a Learning Context Package built by a platform Agent before importing web, document, video, app, Markdown, or Obsidian context into Study Anything.",
        "x-study-anything-output-requirements": [
          "schema_version == learning-context-package-v1",
          "status == valid",
          "package.source_types include web, document, video_slice, app_context, markdown_note, or obsidian_note as applicable",
          "response omits item text"
        ],
        "x-study-anything-privacy": {
          "platform_agent_should_redact_before_logging": [
            "package.items.text",
            "package.items.title"
          ],
          "request_contains_private_learning_data": true,
          "returns_private_learning_data": false
        }
      }
    },
    "/v1/health": {
      "get": {
        "description": "Check that the local Study Anything API is reachable before starting a learning loop.",
