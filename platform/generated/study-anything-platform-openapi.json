            "description": "Bad request"
          },
          "404": {
            "description": "Session or resource not found"
          },
          "409": {
            "description": "Workflow state conflict"
          },
          "503": {
            "description": "Optional dependency unavailable"
          }
        },
        "summary": "Attach web, document, video-slice, or app-context excerpts gathered by the platform agent and convert them into a Study Anything learning source bundle.",
