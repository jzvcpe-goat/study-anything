                  },
                  "use_demo_agent": {
                    "description": "True only for local demos and CI smoke tests.",
                    "type": "boolean"
                  },
                  "user_id": {
                    "minLength": 1,
                    "type": "string"
                  },
                  "workspace_id": {
                    "type": "string"
                  }
                },
                "required": [
                  "package",
                  "user_id"
                ],
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            },
            "description": "Study Anything tool response. See docs/api.md for endpoint-specific response details."
          },
          "400": {
            "description": "Bad request"
          },
          "404": {
            "description": "Session or resource not found"
          },
          "409": {
            "description": "Workflow state conflict"
          },
          "503": {
            "description": "Optional dependency unavailable"
          }
        },
        "summary": "Create a learning session directly from a validated Learning Context Package.",
        "x-study-anything-output-requirements": [
          "schema_version == learning-context-package-v1",
          "status == session_created",
          "session.stage == enrichment_attached",
