                        },
                        "title": {
                          "type": "string"
                        }
                      },
                      "required": [
                        "source_type",
                        "reference",
                        "title",
                        "text"
                      ],
                      "type": "object"
                    },
                    "minItems": 1,
                    "type": "array"
                  },
                  "reference": {
                    "description": "Optional stable reference for the whole enrichment bundle.",
                    "type": "string"
                  },
                  "title": {
                    "default": "Learning Enrichment Bundle",
                    "type": "string"
                  }
                },
                "required": [
                  "items"
                ],
                "type": "object"
              }
            }
          },
          "required": true
