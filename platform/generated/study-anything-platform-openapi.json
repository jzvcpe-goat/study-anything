    },
    "/v1/sessions": {
      "post": {
        "description": "Create a learning session for a local user. Use demo mode only for smoke tests.",
        "operationId": "study_anything_create_session",
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "additionalProperties": false,
                "properties": {
                  "track": {
                    "default": "ACADEMIC",
                    "type": "string"
                  },
                  "use_demo_agent": {
                    "description": "True only for local demos and CI smoke tests. Real learning should use the configured user-owned agent.",
                    "type": "boolean"
                  },
                  "user_id": {
                    "minLength": 1,
                    "type": "string"
                  },
                  "workspace_id": {
                    "type": "string"
                  }
                },
                "required": [
                  "user_id",
                  "track"
                ],
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            },
            "description": "Study Anything tool response. See docs/api.md for endpoint-specific response details."
          },
          "400": {
            "description": "Bad request"
          },
          "404": {
            "description": "Session or resource not found"
          },
          "409": {
            "description": "Workflow state conflict"
          },
          "503": {
            "description": "Optional dependency unavailable"
          }
        },
        "summary": "Create a learning session for a local user. Use demo mode only for smoke tests.",
        "x-study-anything-output-requirements": [
          "session_id is present",
          "stage is initialized or awaiting_source"
        ],
        "x-study-anything-privacy": {
          "returns_private_learning_data": false
        }
      }
    },
