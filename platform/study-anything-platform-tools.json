{
  "schema_version": "study-anything-platform-tools-v1",
  "name": "study-anything-learning-tools",
  "description": "Minimal public tool contract for Codex, Kimi, WorkBuddy-style agents, and private agent workspaces that call Study Anything as a local-first learning engine.",
  "default_api_base": "http://127.0.0.1:8000",
  "api_base_env": "STUDY_ANYTHING_API_BASE",
  "privacy_contract": {
    "platform_agent_owns": [
      "browser access",
      "file access",
      "external data lookup",
      "video or application tooling",
      "model credentials",
      "user-facing conversation"
    ],
    "study_anything_owns": [
      "source-bound session state",
      "learning workflow orchestration",
      "layered teaching output",
      "agent output validation",
      "mastery state",
      "HITL state",
      "redacted agent audit",
      "redacted eval artifact",
      "portable learning package"
    ],
    "must_not_log_or_share": [
      "raw source text",
      "learner answers",
      "grading feedback",
      "generated insights",
      "agent endpoints",
      "agent metadata",
      "API keys or model secrets"
    ]
  },
  "acceptance_evidence": {
    "required_after_learning_loop": [
      "agent_audit.status == verified",
      "agent_eval_artifact.schema_version == agent-eval-artifact-v1",
      "all required native gates pass",
      "agent_eval_artifact.trajectory includes quiz.generate, answer.grade, insight.synthesize",
      "learning_package.schema_version == learning-package-v1"
    ],
    "local_verification_command": "API_BASE=http://127.0.0.1:8000 python3 scripts/verify_platform_agent_tools.py",
    "platform_lesson_command": "API_BASE=http://127.0.0.1:8000 python3 scripts/verify_platform_lesson_flow.py",
    "importer_lesson_command": "API_BASE=http://127.0.0.1:8000 python3 scripts/verify_importer_lesson_flow.py",
    "openai_compatible_gateway_dry_run_command": "API_BASE=http://127.0.0.1:8000 python3 scripts/verify_openai_compatible_gateway.py",
    "gateway_only_command": "python3 scripts/verify_openai_compatible_gateway.py --gateway-only",
    "clean_clone_adoption_command": "python3 scripts/verify_clean_clone_adoption.py --repo .",
    "promptfoo_clean_clone_command": "python3 scripts/verify_clean_clone_adoption.py --repo . --with-promptfoo",
    "retrieval_eval_command": "API_BASE=http://127.0.0.1:8000 python3 scripts/run_external_agent_evals.py --tool retrieval --create-session --required",
    "diagnostics_command": "python3 scripts/diagnose_adoption.py"
  },
  "tools": [
    {
      "name": "study_anything_health",
      "method": "GET",
      "path_template": "/v1/health",
      "description": "Check that the local Study Anything API is reachable before starting a learning loop.",
      "input_schema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {}
      },
      "output_requirements": [
        "status == ok"
      ],
      "privacy": {
        "returns_private_learning_data": false
      }
    },
    {
      "name": "study_anything_create_session",
      "method": "POST",
      "path_template": "/v1/sessions",
      "description": "Create a learning session for a local user. Use demo mode only for smoke tests.",
      "input_schema": {
        "type": "object",
        "required": [
          "user_id",
          "track"
        ],
        "additionalProperties": false,
        "properties": {
          "user_id": {
            "type": "string",
            "minLength": 1
          },
          "track": {
            "type": "string",
            "default": "ACADEMIC"
          },
          "workspace_id": {
            "type": "string"
          },
          "use_demo_agent": {
            "type": "boolean",
            "description": "True only for local demos and CI smoke tests. Real learning should use the configured user-owned agent."
          }
        }
      },
      "output_requirements": [
        "session_id is present",
        "stage is initialized or awaiting_source"
      ],
      "privacy": {
        "returns_private_learning_data": false
      }
    },
    {
      "name": "study_anything_add_reading",
      "method": "POST",
      "path_template": "/v1/sessions/{session_id}/reading",
      "description": "Attach source material gathered by the platform agent to the learning session.",
      "input_schema": {
        "type": "object",
        "required": [
          "session_id",
          "source_type",
          "reference",
          "text"
        ],
        "additionalProperties": false,
        "properties": {
          "session_id": {
            "type": "string",
            "minLength": 1
          },
          "source_type": {
            "type": "string",
            "default": "local_text"
          },
          "reference": {
            "type": "string",
            "description": "Stable citation, URL, file reference, or platform-local source id."
          },
          "title": {
            "type": "string"
          },
          "text": {
            "type": "string",
            "minLength": 1,
            "description": "Source excerpt. Do not include secrets."
          }
        }
      },
      "output_requirements": [
        "source.excerpt_hash is present"
      ],
      "privacy": {
        "request_contains_private_learning_data": true,
        "platform_agent_should_redact_before_logging": [
          "text",
          "title"
        ]
      }
    },
    {
      "name": "study_anything_validate_context_package",
      "method": "POST",
      "path_template": "/v1/context-packages/validate",
      "description": "Validate a Learning Context Package built by a platform Agent before importing web, document, video, app, Markdown, or Obsidian context into Study Anything.",
      "input_schema": {
        "type": "object",
        "required": [
          "package"
        ],
        "additionalProperties": false,
        "properties": {
          "package": {
            "type": "object",
            "additionalProperties": true,
            "description": "learning-context-package-v1 JSON. It may include bounded source excerpts, but must not include Agent credentials or API keys."
          }
        }
      },
      "output_requirements": [
        "schema_version == learning-context-package-v1",
        "status == valid",
        "package.source_types include web, document, video_slice, app_context, markdown_note, or obsidian_note as applicable",
        "response omits item text"
      ],
      "privacy": {
        "request_contains_private_learning_data": true,
        "returns_private_learning_data": false,
        "platform_agent_should_redact_before_logging": [
          "package.items.text",
          "package.items.title"
        ]
      }
    },
    {
      "name": "study_anything_create_session_from_context_package",
      "method": "POST",
      "path_template": "/v1/sessions/from-context-package",
      "description": "Create a learning session directly from a validated Learning Context Package.",
      "input_schema": {
        "type": "object",
        "required": [
          "package",
          "user_id"
        ],
        "additionalProperties": false,
        "properties": {
          "package": {
            "type": "object",
            "additionalProperties": true
          },
          "user_id": {
            "type": "string",
            "minLength": 1
          },
          "track": {
            "type": "string",
            "description": "Optional override. If omitted, Study Anything uses package.track or ACADEMIC."
          },
          "workspace_id": {
            "type": "string"
          },
          "use_demo_agent": {
            "type": "boolean",
            "description": "True only for local demos and CI smoke tests."
          }
        }
      },
      "output_requirements": [
        "schema_version == learning-context-package-v1",
        "status == session_created",
        "session.stage == enrichment_attached",
        "session.enrichment_items include excerpt_hash values"
      ],
      "privacy": {
        "request_contains_private_learning_data": true,
        "returns_private_learning_data": true,
        "platform_agent_should_redact_before_logging": [
          "package.items.text",
          "session.source.text",
          "session.enrichment_items.text"
        ]
      }
    },
    {
      "name": "study_anything_append_context_package",
      "method": "POST",
      "path_template": "/v1/sessions/{session_id}/context-package",
      "description": "Expand an existing learning session with a Learning Context Package.",
      "input_schema": {
        "type": "object",
        "required": [
          "session_id",
          "package"
        ],
        "additionalProperties": false,
        "properties": {
          "session_id": {
            "type": "string",
            "minLength": 1
          },
          "package": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "output_requirements": [
        "schema_version == learning-context-package-v1",
        "status == session_expanded",
        "session.enrichment_items include appended context"
      ],
      "privacy": {
        "request_contains_private_learning_data": true,
        "returns_private_learning_data": true,
        "platform_agent_should_redact_before_logging": [
          "package.items.text",
          "session.source.text",
          "session.enrichment_items.text"
        ]
      }
    },
    {
      "name": "study_anything_run_importer",
      "method": "POST",
      "path_template": "/v1/importers/{plugin_id}/run",
      "description": "Run a locally installed importer plugin after explicit permission confirmation and return a validated Learning Context Package.",
      "input_schema": {
        "type": "object",
        "required": [
          "plugin_id",
          "inputs",
          "confirmed_permissions"
        ],
        "additionalProperties": false,
        "properties": {
          "plugin_id": {
            "type": "string",
            "minLength": 1,
            "description": "Importer plugin id, such as example-note-importer."
          },
          "inputs": {
            "type": "object",
            "additionalProperties": true,
            "description": "Keyword arguments passed to the importer's build_context_package function."
          },
          "confirmed_permissions": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Must match the importer manifest permissions exactly."
          },
          "allow_network": {
            "type": "boolean",
            "default": false,
            "description": "Only true after the platform Agent has reviewed and accepted network:http."
          },
          "include_text": {
            "type": "boolean",
            "default": true
          }
        }
      },
      "output_requirements": [
        "schema_version == importer-run-v1",
        "status == package_created",
        "package.schema_version == learning-context-package-v1",
        "redacted_package omits item text"
      ],
      "privacy": {
        "request_contains_private_learning_data": true,
        "returns_private_learning_data": true,
        "platform_agent_should_redact_before_logging": [
          "inputs",
          "package.items.text",
          "redacted_package.items.title"
        ],
        "network_disabled_by_default": true
      }
    },
    {
      "name": "study_anything_retrieval_status",
      "method": "GET",
      "path_template": "/v1/retrieval/status",
      "description": "Check whether optional retrieval projection is disabled, healthy, or unavailable.",
      "input_schema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {}
      },
      "output_requirements": [
        "status is disabled, healthy, or unavailable"
      ],
      "privacy": {
        "returns_private_learning_data": false
      }
    },
    {
      "name": "study_anything_retrieval_rebuild",
      "method": "POST",
      "path_template": "/v1/sessions/{session_id}/retrieval/rebuild",
      "description": "Rebuild the optional retrieval index for one session from canonical Study Anything session state.",
      "input_schema": {
        "type": "object",
        "required": [
          "session_id"
        ],
        "additionalProperties": false,
        "properties": {
          "session_id": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "output_requirements": [
        "status == rebuilt",
        "indexed_count >= 1"
      ],
      "privacy": {
        "returns_private_learning_data": false,
        "canonical_source": "session_state"
      }
    },
    {
      "name": "study_anything_retrieval_search",
      "method": "POST",
      "path_template": "/v1/sessions/{session_id}/retrieval/search",
      "description": "Search the rebuilt retrieval index for one session and return minimal source snippets.",
      "input_schema": {
        "type": "object",
        "required": [
          "session_id",
          "query"
        ],
        "additionalProperties": false,
        "properties": {
          "session_id": {
            "type": "string",
            "minLength": 1
          },
          "query": {
            "type": "string",
            "minLength": 1
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 20,
            "default": 5
          }
        }
      },
      "output_requirements": [
        "schema_version == retrieval-search-v1",
        "results include reference, excerpt_hash, locator, snippet, and score",
        "full_source_text_returned == false"
      ],
      "privacy": {
        "request_contains_private_learning_data": false,
        "returns_private_learning_data": true,
        "platform_agent_should_redact_before_logging": [
          "query",
          "results.snippet"
        ]
      }
    },
    {
      "name": "study_anything_retrieval_quality_eval",
      "method": "POST",
      "path_template": "/v1/sessions/{session_id}/retrieval/eval",
      "description": "Return redacted retrieval/context quality gates for a rebuilt retrieval index and query.",
      "input_schema": {
        "type": "object",
        "required": [
          "session_id",
          "query"
        ],
        "additionalProperties": false,
        "properties": {
          "session_id": {
            "type": "string",
            "minLength": 1
          },
          "query": {
            "type": "string",
            "minLength": 1
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 20,
            "default": 5
          }
        }
      },
      "output_requirements": [
        "schema_version == retrieval-quality-eval-v1",
        "status == pass or needs_review",
        "quality_score is numeric",
        "gates include retrieval_available, result_count, source_binding, snippet_minimality, query_relevance, context_package_valid",
        "privacy.result_snippets_included == false"
      ],
      "privacy": {
        "returns_private_learning_data": false,
        "must_not_return": [
          "full source text",
          "answers",
          "feedback",
          "agent endpoints",
          "raw agent metadata",
          "secrets",
          "retrieval snippets"
        ]
      }
    },
    {
      "name": "study_anything_create_session_from_retrieval",
      "method": "POST",
      "path_template": "/v1/sessions/from-retrieval",
      "description": "Create a new learning session from retrieval results produced by an existing indexed session.",
      "input_schema": {
        "type": "object",
        "required": [
          "source_session_id",
          "query",
          "user_id"
        ],
        "additionalProperties": false,
        "properties": {
          "source_session_id": {
            "type": "string",
            "minLength": 1
          },
          "query": {
            "type": "string",
            "minLength": 1
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 20,
            "default": 5
          },
          "user_id": {
            "type": "string",
            "minLength": 1
          },
          "track": {
            "type": "string"
          },
          "workspace_id": {
            "type": "string"
          },
          "use_demo_agent": {
            "type": "boolean",
            "description": "True only for local demos and CI smoke tests."
          }
        }
      },
      "output_requirements": [
        "schema_version == retrieval-session-v1",
        "status == session_created",
        "session.stage == enrichment_attached"
      ],
      "privacy": {
        "request_contains_private_learning_data": true,
        "returns_private_learning_data": true,
        "platform_agent_should_redact_before_logging": [
          "query",
          "retrieval.results.snippet",
          "session.source.text"
        ]
      }
    },
    {
      "name": "study_anything_append_retrieval_context",
      "method": "POST",
      "path_template": "/v1/sessions/{session_id}/retrieval/context-package",
      "description": "Expand an existing learning session with a Learning Context Package generated from retrieval results.",
      "input_schema": {
        "type": "object",
        "required": [
          "session_id",
          "source_session_id",
          "query"
        ],
        "additionalProperties": false,
        "properties": {
          "session_id": {
            "type": "string",
            "minLength": 1
          },
          "source_session_id": {
            "type": "string",
            "minLength": 1
          },
          "query": {
            "type": "string",
            "minLength": 1
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 20,
            "default": 5
          }
        }
      },
      "output_requirements": [
        "schema_version == retrieval-session-v1",
        "status == session_expanded",
        "session.enrichment_items include retrieval context"
      ],
      "privacy": {
        "request_contains_private_learning_data": true,
        "returns_private_learning_data": true,
        "platform_agent_should_redact_before_logging": [
          "query",
          "retrieval.results.snippet",
          "session.source.text"
        ]
      }
    },
    {
      "name": "study_anything_add_enrichment",
      "method": "POST",
      "path_template": "/v1/sessions/{session_id}/enrichment",
      "description": "Attach web, document, video-slice, app-context, Markdown, or Obsidian excerpts gathered by the platform agent and convert them into a Study Anything learning source bundle.",
      "input_schema": {
        "type": "object",
        "required": [
          "session_id",
          "items"
        ],
        "additionalProperties": false,
        "properties": {
          "session_id": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "default": "Learning Enrichment Bundle"
          },
          "reference": {
            "type": "string",
            "description": "Optional stable reference for the whole enrichment bundle."
          },
          "items": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": [
                "source_type",
                "reference",
                "title",
                "text",
                "locator",
                "provenance",
                "redaction_policy"
              ],
              "additionalProperties": false,
              "properties": {
                "source_type": {
                  "type": "string",
                  "enum": [
                    "web",
                    "document",
                    "pdf",
                    "video_slice",
                    "video",
                    "app_context",
                    "markdown_note",
                    "obsidian_note"
                  ]
                },
                "reference": {
                  "type": "string"
                },
                "title": {
                  "type": "string"
                },
                "text": {
                  "type": "string",
                  "minLength": 1
                },
                "locator": {
                  "type": "string",
                  "description": "Page, timestamp range, app object id, or other platform-local locator."
                },
                "excerpt_hash": {
                  "type": "string",
                  "description": "Optional sha256 hash supplied by the platform agent; Study Anything recomputes and rejects mismatches."
                },
                "provenance": {
                  "type": "object",
                  "required": [
                    "collector",
                    "capture_method"
                  ],
                  "additionalProperties": true,
                  "properties": {
                    "collector": {
                      "type": "string"
                    },
                    "capture_method": {
                      "type": "string",
                      "enum": [
                        "browser_excerpt",
                        "document_excerpt",
                        "video_transcript_slice",
                        "app_selection",
                        "markdown_excerpt",
                        "obsidian_excerpt",
                        "manual_excerpt",
                        "retrieval_result",
                        "importer_plugin"
                      ]
                    },
                    "source_owner": {
                      "type": "string",
                      "default": "user"
                    },
                    "collected_at": {
                      "type": "string"
                    }
                  }
                },
                "redaction_policy": {
                  "type": "string",
                  "enum": [
                    "reference_only",
                    "hash_and_locator",
                    "summary_only"
                  ],
                  "default": "reference_only"
                },
                "metadata": {
                  "type": "object",
                  "additionalProperties": true
                }
              }
            }
          }
        }
      },
      "output_requirements": [
        "schema_version == learning-enrichment-v1",
        "source.excerpt_hash is present",
        "contract.requires_provenance == true",
        "contract.requires_redaction_policy == true",
        "items contain excerpt_hash but not raw text"
      ],
      "privacy": {
        "request_contains_private_learning_data": true,
        "returns_private_learning_data": true,
        "platform_agent_should_redact_before_logging": [
          "items.text",
          "items.title",
          "source.text"
        ]
      }
    },
    {
      "name": "study_anything_run",
      "method": "POST",
      "path_template": "/v1/sessions/{session_id}/run",
      "description": "Advance the Study Anything workflow after a source is attached or after HITL resolution.",
      "input_schema": {
        "type": "object",
        "required": [
          "session_id"
        ],
        "additionalProperties": false,
        "properties": {
          "session_id": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "output_requirements": [
        "quiz_items contains at least one item, or open_hitl exists"
      ],
      "privacy": {
        "returns_private_learning_data": true,
        "platform_agent_should_redact_before_logging": [
          "quiz_items",
          "source",
          "insights"
        ]
      }
    },
    {
      "name": "study_anything_teaching_layers",
      "method": "POST",
      "path_template": "/v1/sessions/{session_id}/teaching-layers",
      "description": "Generate layered teaching output such as whole-topic overview, glossary, examples, or Obsidian-style notes through user-owned Agent capabilities.",
      "input_schema": {
        "type": "object",
        "required": [
          "session_id",
          "layers"
        ],
        "additionalProperties": false,
        "properties": {
          "session_id": {
            "type": "string",
            "minLength": 1
          },
          "layers": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": [
                "overview",
                "glossary",
                "examples",
                "scribe"
              ]
            },
            "description": "Teaching layers to generate. Each layer routes to a separate Agent capability default."
          },
          "language": {
            "type": "string",
            "default": "zh"
          },
          "level": {
            "type": "string",
            "default": "beginner"
          },
          "max_terms": {
            "type": "integer",
            "minimum": 1,
            "maximum": 50,
            "default": 8
          },
          "example_mode": {
            "type": "string",
            "default": "mixed"
          },
          "constraints": {
            "type": "object",
            "additionalProperties": true
          }
        }
      },
      "output_requirements": [
        "schema_version == teaching-layers-v1",
        "layers contains each requested teaching layer",
        "each layer includes agent.task_type and content"
      ],
      "privacy": {
        "returns_private_learning_data": true,
        "platform_agent_should_redact_before_logging": [
          "layers.content",
          "layers.citations",
          "source"
        ]
      }
    },
    {
      "name": "study_anything_answer",
      "method": "POST",
      "path_template": "/v1/sessions/{session_id}/answers",
      "description": "Submit the learner's answer to one or more quiz items and advance mastery evaluation.",
      "input_schema": {
        "type": "object",
        "required": [
          "session_id",
          "answers"
        ],
        "additionalProperties": false,
        "properties": {
          "session_id": {
            "type": "string",
            "minLength": 1
          },
          "answers": {
            "type": "object",
            "minProperties": 1,
            "additionalProperties": {
              "type": "string"
            },
            "description": "Map of quiz item id to learner answer."
          }
        }
      },
      "output_requirements": [
        "stage == completed or open HITL is returned",
        "mastery.level is present"
      ],
      "privacy": {
        "request_contains_private_learning_data": true,
        "returns_private_learning_data": true,
        "platform_agent_should_redact_before_logging": [
          "answers",
          "grading_results",
          "insights"
        ]
      }
    },
