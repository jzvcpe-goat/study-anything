{
  "schema_version": "ecosystem-submission-v1",
  "name": "Study Anything Ecosystem Submission Pack",
  "version": "v0.3.4-alpha",
  "summary": "Submission-ready local-first integration metadata for Kimi-compatible, Codex Skill, WorkBuddy-style HTTP, and generic OpenAPI tool platforms.",
  "project": {
    "repository": "https://github.com/jzvcpe-goat/study-anything",
    "license": "Apache-2.0",
    "distribution_model": "open-source local-first core",
    "standalone_frontend_required": false,
    "billing_required": false,
    "hosted_services_in_mvp": false
  },
  "positioning": {
    "primary_user_experience": "The external platform Agent remains the user's conversation, browsing, file, and tool surface. Study Anything runs as a local learning engine behind platform tools or a Codex Skill.",
    "study_anything_owns": [
      "source-bound learning workflow",
      "agent task contracts and output validation",
      "mastery state",
      "redacted audit and eval evidence",
      "retrieval quality checks",
      "Obsidian and NotebookLM-style exports",
      "aggregate adoption telemetry",
      "PMF readiness summary"
    ],
    "platform_agent_owns": [
      "browser access",
      "file and application access",
      "external data lookup",
      "video slicing and media tooling",
      "real model credentials",
      "user-facing conversation"
    ]
  },
  "privacy": {
    "real_model_keys_stored_by_study_anything": false,
    "agent_endpoints_in_submission": false,
    "raw_learning_data_in_submission": false,
    "management_endpoints_exposed_to_platform_tools": false,
    "must_not_log_or_share": [
      "raw source text",
      "learner answers",
      "grading feedback",
      "generated insights",
      "agent endpoints",
      "agent metadata",
      "API keys or model secrets",
      "raw user ids",
      "browser/video/app private context"
    ]
  },
  "commercial_readiness": {
    "contract": "commercial-readiness-v1",
    "endpoint": "/v1/commercial/readiness",
    "ready_paths": [
      "github_oss_launch",
      "platform_agent_distribution"
    ],
    "not_ready_paths": [
      "hosted_paid_services",
      "managed_sync",
      "managed_teams"
    ],
    "monetization_boundary": "Do not sell a standalone app during this phase. Commercial work should prepare future hosted sync, hosted publishing, team workspaces, and a trusted plugin ecosystem without locking the OSS workflow."
  },
  "shared_assets": [
    "platform/study-anything-platform-tools.json",
    "platform/generated/study-anything-platform-openapi.json",
    "platform/generated/study-anything-openai-tools.json",
    "platform/generated/study-anything-tool-catalog.md",
    "platform/generated/study-anything-platform-bundle.json",
    "platform/generated/study-anything-platform-adoption-pack.zip",
    "docs/ecosystem-submission.md",
    "docs/platform-agent-integrations.md",
    "docs/use-with-kimi.md",
    "docs/commercial-readiness.md",
    "docs/adoption.md",
    "docs/adoption-telemetry.md",
    "scripts/verify_adoption_telemetry.py",
    "scripts/verify_agent_gateway_hardening.py",
    "scripts/verify_notebooklm_obsidian_bridge_hardening.py"
  ],
  "submissions": [
    {
      "platform_id": "kimi-compatible",
      "display_name": "Kimi-compatible Tool Workspace",
      "submission_status": "ready_for_manual_submission",
      "integration_mode": "openai_compatible_tools",
      "no_frontend_required": true,
      "entrypoints": {
        "openai_tools": "platform/generated/study-anything-openai-tools.json",
        "openapi": "platform/generated/study-anything-platform-openapi.json",
        "gateway": "scripts/openai_compatible_agent_gateway.py",
        "guide": "docs/use-with-kimi.md",
        "pack": "platform/packs/kimi/pack.json"
      },
      "import_assets": [
        "platform/generated/study-anything-openai-tools.json",
        "platform/generated/study-anything-platform-openapi.json",
        "platform/generated/study-anything-tool-catalog.md",
        "platform/packs/kimi/README.md"
      ],
      "verification_commands": [
        "python3 scripts/verify_ecosystem_submission_pack.py",
        "python3 scripts/verify_adoption_telemetry.py --api-base http://127.0.0.1:8000",
        "python3 scripts/verify_agent_gateway_hardening.py",
        "python3 scripts/verify_notebooklm_obsidian_bridge_hardening.py",
        "python3 scripts/verify_openai_compatible_gateway.py --gateway-only",
        "API_BASE=http://127.0.0.1:8000 python3 scripts/verify_openai_compatible_gateway.py",
        "python3 scripts/verify_external_adoption.py --pack platform/generated/study-anything-platform-adoption-pack.zip --copy-worktree"
      ],
      "known_limits": [
        "Browser-only Kimi chat cannot reach localhost directly.",
        "Kimi or Moonshot credentials stay in the user's gateway or platform environment.",
        "The submission pack does not include raw learning content or private platform context."
      ]
    },
    {
      "platform_id": "codex-skill",
      "display_name": "Codex Skill",
      "submission_status": "ready_for_repo_local_use",
      "integration_mode": "terminal_skill",
      "no_frontend_required": true,
      "entrypoints": {
        "skill": "skills/study-anything/SKILL.md",
        "cli": "scripts/study_anything_cli.py",
        "demo": "scripts/run_skill_mode_demo.sh",
        "pack": "platform/packs/codex/pack.json"
      },
      "import_assets": [
        "skills/study-anything/SKILL.md",
        "scripts/study_anything_cli.py",
        "platform/generated/study-anything-tool-catalog.md",
        "platform/packs/codex/README.md"
      ],
      "verification_commands": [
        "python3 scripts/verify_ecosystem_submission_pack.py",
        "python3 scripts/verify_adoption_telemetry.py --api-base http://127.0.0.1:8000",
        "python3 scripts/verify_notebooklm_obsidian_bridge_hardening.py",
        "./scripts/run_skill_mode_demo.sh",
        "python3 scripts/verify_commercial_readiness.py",
        "python3 scripts/verify_external_adoption.py --pack platform/generated/study-anything-platform-adoption-pack.zip --copy-worktree"
      ],
      "known_limits": [
        "Requires a terminal-capable Agent with local checkout access.",
        "The Skill launches or calls a local Study Anything API instead of becoming a standalone chat product."
      ]
    },
    {
      "platform_id": "workbuddy-style-http",
      "display_name": "WorkBuddy-style HTTP Workspace",
      "submission_status": "ready_for_manual_submission",
      "integration_mode": "openapi_http_tools",
      "no_frontend_required": true,
      "entrypoints": {
        "openapi": "platform/generated/study-anything-platform-openapi.json",
        "tool_catalog": "platform/generated/study-anything-tool-catalog.md",
        "api_docs": "docs/api.md",
        "pack": "platform/packs/workbuddy/pack.json"
      },
      "import_assets": [
        "platform/generated/study-anything-platform-openapi.json",
        "platform/generated/study-anything-tool-catalog.md",
        "platform/packs/workbuddy/README.md"
      ],
      "verification_commands": [
        "python3 scripts/verify_ecosystem_submission_pack.py",
        "python3 scripts/verify_adoption_telemetry.py --api-base http://127.0.0.1:8000",
        "python3 scripts/verify_notebooklm_obsidian_bridge_hardening.py",
        "API_BASE=http://127.0.0.1:8000 python3 scripts/verify_platform_agent_tools.py",
        "STUDY_ANYTHING_RETRIEVAL_BACKEND=memory API_BASE=http://127.0.0.1:8000 python3 scripts/verify_platform_ecosystem_eval_flow.py",
        "python3 scripts/verify_external_adoption.py --pack platform/generated/study-anything-platform-adoption-pack.zip --copy-worktree"
      ],
      "known_limits": [
        "The workspace must be able to call a local or private HTTP endpoint.",
        "Admin, provider setup, sync export, restore preview, and PMF export endpoints are intentionally excluded."
      ]
    },
    {
      "platform_id": "generic-openapi-tools",
      "display_name": "Generic OpenAPI Tool Platform",
      "submission_status": "ready_for_manual_submission",
      "integration_mode": "generic_openapi_tools",
      "no_frontend_required": true,
      "entrypoints": {
        "openapi": "platform/generated/study-anything-platform-openapi.json",
        "tool_catalog": "platform/generated/study-anything-tool-catalog.md",
        "integration_guide": "docs/platform-agent-integrations.md"
      },
      "import_assets": [
        "platform/generated/study-anything-platform-openapi.json",
        "platform/generated/study-anything-tool-catalog.md",
        "docs/platform-agent-integrations.md"
      ],
      "verification_commands": [
        "python3 scripts/verify_ecosystem_submission_pack.py",
        "python3 scripts/verify_adoption_telemetry.py --api-base http://127.0.0.1:8000",
        "python3 scripts/verify_notebooklm_obsidian_bridge_hardening.py",
        "python3 scripts/generate_platform_agent_assets.py --check",
        "python3 scripts/verify_platform_operator_drill.py --check",
        "python3 scripts/verify_external_adoption.py --pack platform/generated/study-anything-platform-adoption-pack.zip --copy-worktree"
      ],
      "known_limits": [
        "OpenAPI import behavior differs by host platform; use the tool catalog as the fallback mapping.",
        "The pack is for local-first OSS adoption, not managed hosting or marketplace payments."
      ]
    }
  ],
  "acceptance": {
    "schema": "ecosystem-submission-verification-v1",
    "minimum_commands": [
      "python3 scripts/verify_ecosystem_submission_pack.py",
      "python3 scripts/verify_commercial_readiness.py",
      "python3 scripts/verify_adoption_telemetry.py",
      "python3 scripts/verify_agent_gateway_hardening.py",
      "python3 scripts/verify_notebooklm_obsidian_bridge_hardening.py",
      "python3 scripts/verify_platform_ecosystem_packs.py",
      "python3 scripts/generate_platform_bundle_manifest.py --check",
      "python3 scripts/generate_platform_adoption_pack.py --check",
      "python3 scripts/verify_external_adoption.py --pack platform/generated/study-anything-platform-adoption-pack.zip --copy-worktree"
    ],
    "must_prove": [
      "all submission assets exist",
      "all platform packs remain aligned",
      "platform tool manifest excludes management endpoints",
      "submission metadata declares no standalone frontend requirement",
      "submission metadata declares no Study Anything model-key custody",
      "commercial-readiness-v1 remains linked",
      "adoption-telemetry-v1 remains aggregate-only",
      "agent-gateway-hardening-verification-v1 blocks unsafe provider config and bad Agent output",
      "notebooklm-obsidian-bridge-hardening-v1 blocks hidden instructions, dedupes fixture imports, and verifies strict handoff privacy",
      "pmf-readiness-v1 keeps hosted paid services not_ready"
    ]
  },
  "adoption_telemetry": {
    "contract": "adoption-telemetry-v1",
    "endpoint": "/v1/adoption/telemetry",
    "readiness_contract": "pmf-readiness-v1",
    "readiness_endpoint": "/v1/pmf/readiness",
    "verifier": "scripts/verify_adoption_telemetry.py",
    "aggregate_only": true,
    "automatic_upload": false,
    "forbidden_fields": [
      "source text",
      "learner answers",
      "generated insights",
      "raw user ids",
      "agent endpoints",
      "API keys",
      "browser/video/app private context"
    ]
  }
}
