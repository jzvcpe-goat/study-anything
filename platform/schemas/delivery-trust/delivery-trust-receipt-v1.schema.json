{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "delivery-trust-receipt-v1",
  "title": "Delivery Trust Receipt v1",
  "type": "object",
  "required": [
    "schema_version",
    "receipt_id",
    "project_id",
    "candidate_artifact_ref",
    "status",
    "decision",
    "reasons",
    "dual_loop_refs",
    "trust_basis",
    "checks",
    "customer_delivery_scope",
    "claim_boundary",
    "isolation",
    "privacy"
  ],
  "properties": {
    "schema_version": {
      "const": "delivery-trust-receipt-v1"
    },
    "status": {
      "enum": [
        "allowed",
        "blocked"
      ]
    },
    "decision": {
      "enum": [
        "allow_controlled_customer_handoff",
        "block_customer_handoff"
      ]
    },
    "reasons": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "trust_basis": {
      "type": "object",
      "required": [
        "controlled_failure_environment",
        "human_attention_reconstruction",
        "dual_loop_propagation_gate",
        "ai_eval_receipts_role",
        "human_review_role"
      ],
      "properties": {
        "controlled_failure_environment": {
          "const": "required"
        },
        "human_attention_reconstruction": {
          "const": "required"
        },
        "dual_loop_propagation_gate": {
          "const": "required"
        },
        "ai_eval_receipts_role": {
          "const": "supporting_only_not_sufficient"
        },
        "human_review_role": {
          "const": "active_reconstruction_not_full_manual_re_review"
        }
      }
    },
    "checks": {
      "type": "object",
      "required": [
        "failure_contract_valid",
        "sandbox_receipt_valid",
        "dual_loop_gate_allowed",
        "controlled_failure_environment_passed",
        "human_reconstruction_present",
        "human_reconstruction_passed",
        "structured_artifact_bridge_only",
        "no_ai_review_black_box_as_sole_basis",
        "no_excessive_manual_re_review_required",
        "production_mutation_blocked",
        "reversible_delivery_path",
        "customer_claim_boundary_present"
      ],
      "properties": {
        "structured_artifact_bridge_only": {
          "const": true
        },
        "no_ai_review_black_box_as_sole_basis": {
          "const": true
        },
        "no_excessive_manual_re_review_required": {
          "const": true
        },
        "production_mutation_blocked": {
          "const": true
        },
        "customer_claim_boundary_present": {
          "const": true
        }
      }
    },
    "customer_delivery_scope": {
      "type": "object",
      "required": [
        "scope_id",
        "allowed_handoff",
        "production_mutation_allowed",
        "irreversible_external_effects_allowed",
        "real_customer_effects_allowed"
      ],
      "properties": {
        "production_mutation_allowed": {
          "const": false
        },
        "irreversible_external_effects_allowed": {
          "const": false
        },
        "real_customer_effects_allowed": {
          "const": false
        }
      }
    },
    "claim_boundary": {
      "type": "object",
      "required": [
        "current_claim",
        "not_claimed",
        "requires_before_real_production"
      ],
      "properties": {
        "current_claim": {
          "type": "string",
          "minLength": 1
        },
        "not_claimed": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "requires_before_real_production": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
