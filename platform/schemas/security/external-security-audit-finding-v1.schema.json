{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://study-anything.local/schemas/security/external-security-audit-finding-v1.schema.json",
  "title": "External Security Audit Finding v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "finding_id",
    "status",
    "severity",
    "title",
    "category",
    "scope_commit",
    "affected_surface",
    "evidence",
    "impact_summary",
    "remediation",
    "retest",
    "privacy"
  ],
  "properties": {
    "schema_version": {
      "const": "external-security-audit-finding-v1"
    },
    "finding_id": {
      "type": "string",
      "pattern": "^AUD-[0-9]{4}$"
    },
    "status": {
      "enum": [
        "open",
        "remediated",
        "verified",
        "risk_accepted"
      ]
    },
    "severity": {
      "enum": [
        "critical",
        "high",
        "medium",
        "low",
        "informational"
      ]
    },
    "title": {
      "type": "string",
      "minLength": 5,
      "maxLength": 160
    },
    "category": {
      "type": "string",
      "minLength": 3,
      "maxLength": 80
    },
    "scope_commit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "affected_surface": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "component",
        "public_reference"
      ],
      "properties": {
        "component": {
          "type": "string",
          "minLength": 2,
          "maxLength": 120
        },
        "public_reference": {
          "type": "string",
          "minLength": 2,
          "maxLength": 240
        }
      }
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "artifact_ref",
          "sha256",
          "observation"
        ],
        "properties": {
          "artifact_ref": {
            "type": "string",
            "minLength": 2,
            "maxLength": 240
          },
          "sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          },
          "observation": {
            "type": "string",
            "minLength": 3,
            "maxLength": 500
          }
        }
      }
    },
    "impact_summary": {
      "type": "string",
      "minLength": 3,
      "maxLength": 1000
    },
    "remediation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "owner",
        "target_date",
        "commit_ref"
      ],
      "properties": {
        "owner": {
          "type": "string",
          "minLength": 2,
          "maxLength": 120
        },
        "target_date": {
          "type": "string",
          "format": "date"
        },
        "commit_ref": {
          "type": [
            "string",
            "null"
          ],
          "pattern": "^[0-9a-f]{40}$"
        }
      }
    },
    "retest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required",
        "status"
      ],
      "properties": {
        "required": {
          "type": "boolean"
        },
        "status": {
          "enum": [
            "not_started",
            "passed",
            "failed",
            "not_required"
          ]
        }
      }
    },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "metadata_only_public_record",
        "real_secrets_included",
        "customer_payloads_included",
        "private_exploit_details_included"
      ],
      "properties": {
        "metadata_only_public_record": {
          "const": true
        },
        "real_secrets_included": {
          "const": false
        },
        "customer_payloads_included": {
          "const": false
        },
        "private_exploit_details_included": {
          "const": false
        }
      }
    }
  }
}
