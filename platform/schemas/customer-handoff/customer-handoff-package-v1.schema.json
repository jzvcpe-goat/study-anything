{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "customer-handoff-package-v1",
  "title": "Customer Handoff Package v1",
  "type": "object",
  "required": [
    "schema_version",
    "package_id",
    "project_id",
    "candidate_artifact_ref",
    "status",
    "decision",
    "manifest",
    "delivery_trust_receipt",
    "claim_boundary",
    "limitations",
    "rollback_strategy",
    "controlled_failure_summary",
    "human_reconstruction_summary",
    "dual_loop_gate_receipt",
    "external_eval_receipts",
    "artifact_refs",
    "agent_handoff_instructions",
    "provenance",
    "customer_delivery_scope",
    "isolation",
    "privacy"
  ],
  "properties": {
    "schema_version": {
      "const": "customer-handoff-package-v1"
    },
    "status": {
      "const": "ready_for_controlled_customer_handoff"
    },
    "decision": {
      "const": "package_controlled_customer_handoff"
    },
    "manifest": {
      "type": "object",
      "required": [
        "schema_version",
        "package_schema_version",
        "package_id",
        "entrypoint",
        "artifacts",
        "zip_root"
      ],
      "properties": {
        "schema_version": {
          "const": "customer-handoff-package-manifest-v1"
        },
        "package_schema_version": {
          "const": "customer-handoff-package-v1"
        },
        "entrypoint": {
          "const": "customer-handoff-package.json"
        },
        "artifacts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "path",
              "package_key",
              "kind",
              "sha256",
              "bytes"
            ],
            "properties": {
              "sha256": {
                "type": "string",
                "pattern": "^[a-f0-9]{64}$"
              },
              "bytes": {
                "type": "integer",
                "minimum": 1
              }
            }
          }
        }
      }
    },
    "delivery_trust_receipt": {
      "type": "object",
      "required": [
        "schema_version",
        "status",
        "decision"
      ],
      "properties": {
        "schema_version": {
          "const": "delivery-trust-receipt-v1"
        },
        "status": {
          "const": "allowed"
        },
        "decision": {
          "const": "allow_controlled_customer_handoff"
        }
      }
    },
    "external_eval_receipts": {
      "type": "object",
      "required": [
        "role",
        "trust_sufficient",
        "receipts"
      ],
      "properties": {
        "role": {
          "const": "supporting_only_not_sufficient"
        },
        "trust_sufficient": {
          "const": false
        }
      }
    },
    "customer_delivery_scope": {
      "type": "object",
      "required": [
        "scope_id",
        "allowed_handoff",
        "production_mutation_allowed",
        "irreversible_external_effects_allowed",
        "real_customer_effects_allowed"
      ],
      "properties": {
        "allowed_handoff": {
          "const": true
        },
        "production_mutation_allowed": {
          "const": false
        },
        "irreversible_external_effects_allowed": {
          "const": false
        },
        "real_customer_effects_allowed": {
          "const": false
        }
      }
    },
    "rollback_strategy": {
      "type": "object",
      "required": [
        "available",
        "rehearsed",
        "rollback_ref",
        "production_mutation_required"
      ],
      "properties": {
        "available": {
          "const": true
        },
        "rehearsed": {
          "const": true
        },
        "production_mutation_required": {
          "const": false
        }
      }
    },
    "agent_handoff_instructions": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "required": [
          "platform_id",
          "allowed_actions",
          "forbidden_actions",
          "production_mutation_allowed",
          "scope_escalation_allowed",
          "automatic_customer_sending_allowed"
        ],
        "properties": {
          "production_mutation_allowed": {
            "const": false
          },
          "scope_escalation_allowed": {
            "const": false
          },
          "automatic_customer_sending_allowed": {
            "const": false
          }
        }
      }
    },
    "claim_boundary": {
      "type": "object",
      "required": [
        "current_claim",
        "not_claimed",
        "requires_before_real_production"
      ],
      "properties": {
        "current_claim": {
          "type": "string",
          "minLength": 1
        },
        "not_claimed": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "requires_before_real_production": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
