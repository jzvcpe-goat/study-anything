{
  "$id": "cbb-self-intake-receipt-v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": true,
  "properties": {
    "checks": {
      "type": "object"
    },
    "ci_checks": {
      "items": {
        "type": "object"
      },
      "minItems": 1,
      "type": "array"
    },
    "claim_boundary": {
      "type": "object"
    },
    "decision": {
      "enum": [
        "self_intake_passed",
        "block_self_intake"
      ],
      "type": "string"
    },
    "privacy": {
      "type": "object"
    },
    "project_id": {
      "minLength": 1,
      "type": "string"
    },
    "reasons": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "receipt_chain": {
      "type": "object"
    },
    "reviewer_reconstruction_summary": {
      "type": "object"
    },
    "schema_version": {
      "const": "cbb-self-intake-receipt-v1"
    },
    "self_intake_id": {
      "minLength": 1,
      "type": "string"
    },
    "source": {
      "type": "object"
    },
    "status": {
      "enum": [
        "passed",
        "blocked"
      ],
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "self_intake_id",
    "project_id",
    "source",
    "ci_checks",
    "receipt_chain",
    "status",
    "decision",
    "reasons",
    "checks",
    "reviewer_reconstruction_summary",
    "claim_boundary",
    "privacy"
  ],
  "title": "CBB Self-Intake Receipt v1",
  "type": "object"
}
