{
  "$defs": {
    "ClaimBoundaryV1": {
      "additionalProperties": false,
      "properties": {
        "current_claim": {
          "maxLength": 2000,
          "minLength": 1,
          "title": "Current Claim",
          "type": "string"
        },
        "maximum_scope": {
          "$ref": "#/$defs/DeliveryScope"
        },
        "not_claimed": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Not Claimed",
          "type": "array"
        }
      },
      "required": [
        "current_claim",
        "maximum_scope",
        "not_claimed"
      ],
      "title": "ClaimBoundaryV1",
      "type": "object"
    },
    "DeliveryScope": {
      "description": "Ordered scopes from no release authority to a production candidate.",
      "enum": [
        "blocked",
        "personal_local",
        "sandbox_only",
        "public_demo",
        "internal_handoff",
        "controlled_customer_handoff",
        "limited_beta",
        "production_candidate"
      ],
      "title": "DeliveryScope",
      "type": "string"
    },
    "PluginEvidencePrivacyV1": {
      "additionalProperties": false,
      "properties": {
        "external_input_content_included": {
          "const": false,
          "title": "External Input Content Included",
          "type": "boolean"
        },
        "local_absolute_paths_included": {
          "const": false,
          "title": "Local Absolute Paths Included",
          "type": "boolean"
        },
        "plugin_source_included": {
          "const": false,
          "title": "Plugin Source Included",
          "type": "boolean"
        },
        "protocol_boundary": {
          "$ref": "#/$defs/PrivacyBoundaryV1"
        },
        "raw_check_output_included": {
          "const": false,
          "title": "Raw Check Output Included",
          "type": "boolean"
        }
      },
      "required": [
        "protocol_boundary",
        "plugin_source_included",
        "raw_check_output_included",
        "external_input_content_included",
        "local_absolute_paths_included"
      ],
      "title": "PluginEvidencePrivacyV1",
      "type": "object"
    },
    "PrivacyBoundaryV1": {
      "additionalProperties": false,
      "properties": {
        "attention_stream_included": {
          "const": false,
          "title": "Attention Stream Included",
          "type": "boolean"
        },
        "automatic_customer_send_performed": {
          "const": false,
          "title": "Automatic Customer Send Performed",
          "type": "boolean"
        },
        "cookies_or_bearer_tokens_included": {
          "const": false,
          "title": "Cookies Or Bearer Tokens Included",
          "type": "boolean"
        },
        "metadata_only": {
          "const": true,
          "title": "Metadata Only",
          "type": "boolean"
        },
        "model_credentials_included": {
          "const": false,
          "title": "Model Credentials Included",
          "type": "boolean"
        },
        "model_prompts_included": {
          "const": false,
          "title": "Model Prompts Included",
          "type": "boolean"
        },
        "production_mutation_performed": {
          "const": false,
          "title": "Production Mutation Performed",
          "type": "boolean"
        },
        "raw_customer_payload_included": {
          "const": false,
          "title": "Raw Customer Payload Included",
          "type": "boolean"
        },
        "raw_report_text_included": {
          "const": false,
          "title": "Raw Report Text Included",
          "type": "boolean"
        },
        "raw_source_text_included": {
          "const": false,
          "title": "Raw Source Text Included",
          "type": "boolean"
        },
        "signed_urls_included": {
          "const": false,
          "title": "Signed Urls Included",
          "type": "boolean"
        }
      },
      "required": [
        "metadata_only",
        "raw_source_text_included",
        "raw_report_text_included",
        "raw_customer_payload_included",
        "attention_stream_included",
        "model_prompts_included",
        "model_credentials_included",
        "cookies_or_bearer_tokens_included",
        "signed_urls_included",
        "production_mutation_performed",
        "automatic_customer_send_performed"
      ],
      "title": "PrivacyBoundaryV1",
      "type": "object"
    }
  },
  "$id": "delivery-clearance.plugin-evidence-decision.v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "approved_scope": {
      "$ref": "#/$defs/DeliveryScope"
    },
    "checks": {
      "additionalProperties": {
        "type": "boolean"
      },
      "title": "Checks",
      "type": "object"
    },
    "claim_boundary": {
      "$ref": "#/$defs/ClaimBoundaryV1"
    },
    "customer_delivery_authorized": {
      "const": false,
      "title": "Customer Delivery Authorized",
      "type": "boolean"
    },
    "decision_id": {
      "pattern": "^[a-z0-9][a-z0-9._:-]{0,159}$",
      "title": "Decision Id",
      "type": "string"
    },
    "evaluated_at": {
      "maxLength": 64,
      "minLength": 1,
      "title": "Evaluated At",
      "type": "string"
    },
    "evidence_digest_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Evidence Digest Sha256",
      "type": "string"
    },
    "evidence_ref": {
      "pattern": "^[a-z0-9][a-z0-9._:-]{0,159}$",
      "title": "Evidence Ref",
      "type": "string"
    },
    "external_action_authorized": {
      "const": false,
      "title": "External Action Authorized",
      "type": "boolean"
    },
    "manifest_or_install_state_sufficient": {
      "const": false,
      "title": "Manifest Or Install State Sufficient",
      "type": "boolean"
    },
    "missing_evidence": {
      "items": {
        "type": "string"
      },
      "title": "Missing Evidence",
      "type": "array"
    },
    "plugin_id": {
      "pattern": "^[a-z0-9][a-z0-9._-]{0,119}$",
      "title": "Plugin Id",
      "type": "string"
    },
    "privacy": {
      "$ref": "#/$defs/PluginEvidencePrivacyV1"
    },
    "production_authorized": {
      "const": false,
      "title": "Production Authorized",
      "type": "boolean"
    },
    "reasons": {
      "items": {
        "type": "string"
      },
      "title": "Reasons",
      "type": "array"
    },
    "schema_version": {
      "const": "delivery-clearance.plugin-evidence-decision.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "status": {
      "enum": [
        "allow_personal_local",
        "needs_evidence",
        "block"
      ],
      "title": "Status",
      "type": "string"
    },
    "valid_until": {
      "maxLength": 64,
      "minLength": 1,
      "title": "Valid Until",
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "decision_id",
    "evidence_ref",
    "evidence_digest_sha256",
    "plugin_id",
    "status",
    "approved_scope",
    "checks",
    "reasons",
    "missing_evidence",
    "evaluated_at",
    "valid_until",
    "manifest_or_install_state_sufficient",
    "customer_delivery_authorized",
    "production_authorized",
    "external_action_authorized",
    "claim_boundary",
    "privacy"
  ],
  "title": "PluginEvidenceDecisionV1",
  "type": "object"
}
