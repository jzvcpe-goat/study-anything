{
  "$defs": {
    "ClaimBoundaryV1": {
      "additionalProperties": false,
      "properties": {
        "current_claim": {
          "maxLength": 2000,
          "minLength": 1,
          "title": "Current Claim",
          "type": "string"
        },
        "maximum_scope": {
          "$ref": "#/$defs/DeliveryScope"
        },
        "not_claimed": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Not Claimed",
          "type": "array"
        }
      },
      "required": [
        "current_claim",
        "maximum_scope",
        "not_claimed"
      ],
      "title": "ClaimBoundaryV1",
      "type": "object"
    },
    "DeliveryScope": {
      "description": "Ordered scopes from no release authority to a production candidate.",
      "enum": [
        "blocked",
        "personal_local",
        "sandbox_only",
        "public_demo",
        "internal_handoff",
        "controlled_customer_handoff",
        "limited_beta",
        "production_candidate"
      ],
      "title": "DeliveryScope",
      "type": "string"
    },
    "PrivacyBoundaryV1": {
      "additionalProperties": false,
      "properties": {
        "attention_stream_included": {
          "const": false,
          "title": "Attention Stream Included",
          "type": "boolean"
        },
        "automatic_customer_send_performed": {
          "const": false,
          "title": "Automatic Customer Send Performed",
          "type": "boolean"
        },
        "cookies_or_bearer_tokens_included": {
          "const": false,
          "title": "Cookies Or Bearer Tokens Included",
          "type": "boolean"
        },
        "metadata_only": {
          "const": true,
          "title": "Metadata Only",
          "type": "boolean"
        },
        "model_credentials_included": {
          "const": false,
          "title": "Model Credentials Included",
          "type": "boolean"
        },
        "model_prompts_included": {
          "const": false,
          "title": "Model Prompts Included",
          "type": "boolean"
        },
        "production_mutation_performed": {
          "const": false,
          "title": "Production Mutation Performed",
          "type": "boolean"
        },
        "raw_customer_payload_included": {
          "const": false,
          "title": "Raw Customer Payload Included",
          "type": "boolean"
        },
        "raw_report_text_included": {
          "const": false,
          "title": "Raw Report Text Included",
          "type": "boolean"
        },
        "raw_source_text_included": {
          "const": false,
          "title": "Raw Source Text Included",
          "type": "boolean"
        },
        "signed_urls_included": {
          "const": false,
          "title": "Signed Urls Included",
          "type": "boolean"
        }
      },
      "required": [
        "metadata_only",
        "raw_source_text_included",
        "raw_report_text_included",
        "raw_customer_payload_included",
        "attention_stream_included",
        "model_prompts_included",
        "model_credentials_included",
        "cookies_or_bearer_tokens_included",
        "signed_urls_included",
        "production_mutation_performed",
        "automatic_customer_send_performed"
      ],
      "title": "PrivacyBoundaryV1",
      "type": "object"
    }
  },
  "$id": "delivery-clearance.personal-boundary-reconstruction.v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "active_reconstruction_complete": {
      "title": "Active Reconstruction Complete",
      "type": "boolean"
    },
    "claim_boundary": {
      "$ref": "#/$defs/ClaimBoundaryV1"
    },
    "config_digest_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Config Digest Sha256",
      "type": "string"
    },
    "critical_failure_path": {
      "maxLength": 2000,
      "minLength": 1,
      "title": "Critical Failure Path",
      "type": "string"
    },
    "evidence_limitations": {
      "items": {
        "type": "string"
      },
      "maxItems": 20,
      "minItems": 1,
      "title": "Evidence Limitations",
      "type": "array"
    },
    "independent_review_performed": {
      "const": false,
      "title": "Independent Review Performed",
      "type": "boolean"
    },
    "non_goals": {
      "items": {
        "type": "string"
      },
      "maxItems": 20,
      "minItems": 1,
      "title": "Non Goals",
      "type": "array"
    },
    "observed_at": {
      "maxLength": 64,
      "minLength": 1,
      "title": "Observed At",
      "type": "string"
    },
    "privacy": {
      "$ref": "#/$defs/PrivacyBoundaryV1"
    },
    "project_ref": {
      "maxLength": 160,
      "minLength": 1,
      "title": "Project Ref",
      "type": "string"
    },
    "purpose": {
      "maxLength": 1000,
      "minLength": 1,
      "title": "Purpose",
      "type": "string"
    },
    "responsibility_accepted_for_this_run": {
      "title": "Responsibility Accepted For This Run",
      "type": "boolean"
    },
    "reviewer_kind": {
      "const": "self",
      "title": "Reviewer Kind",
      "type": "string"
    },
    "risk_owner_kind": {
      "const": "self",
      "title": "Risk Owner Kind",
      "type": "string"
    },
    "rollback_strategy": {
      "maxLength": 2000,
      "minLength": 1,
      "title": "Rollback Strategy",
      "type": "string"
    },
    "rollback_trigger": {
      "maxLength": 1000,
      "minLength": 1,
      "title": "Rollback Trigger",
      "type": "string"
    },
    "schema_version": {
      "const": "delivery-clearance.personal-boundary-reconstruction.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "unresolved_config_fields": {
      "items": {
        "type": "string"
      },
      "title": "Unresolved Config Fields",
      "type": "array"
    },
    "valid_until": {
      "maxLength": 64,
      "minLength": 1,
      "title": "Valid Until",
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "project_ref",
    "config_digest_sha256",
    "reviewer_kind",
    "risk_owner_kind",
    "responsibility_accepted_for_this_run",
    "active_reconstruction_complete",
    "unresolved_config_fields",
    "purpose",
    "non_goals",
    "critical_failure_path",
    "rollback_trigger",
    "rollback_strategy",
    "evidence_limitations",
    "observed_at",
    "valid_until",
    "independent_review_performed",
    "claim_boundary",
    "privacy"
  ],
  "title": "PersonalBoundaryReconstructionV1",
  "type": "object"
}
