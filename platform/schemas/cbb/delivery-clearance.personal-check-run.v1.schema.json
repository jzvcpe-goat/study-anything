{
  "$defs": {
    "ClaimBoundaryV1": {
      "additionalProperties": false,
      "properties": {
        "current_claim": {
          "maxLength": 2000,
          "minLength": 1,
          "title": "Current Claim",
          "type": "string"
        },
        "maximum_scope": {
          "$ref": "#/$defs/DeliveryScope"
        },
        "not_claimed": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Not Claimed",
          "type": "array"
        }
      },
      "required": [
        "current_claim",
        "maximum_scope",
        "not_claimed"
      ],
      "title": "ClaimBoundaryV1",
      "type": "object"
    },
    "DeliveryScope": {
      "description": "Ordered scopes from no release authority to a production candidate.",
      "enum": [
        "blocked",
        "personal_local",
        "sandbox_only",
        "public_demo",
        "internal_handoff",
        "controlled_customer_handoff",
        "limited_beta",
        "production_candidate"
      ],
      "title": "DeliveryScope",
      "type": "string"
    },
    "PersonalCheckResultV1": {
      "additionalProperties": false,
      "properties": {
        "argv_digest_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Argv Digest Sha256",
          "type": "string"
        },
        "check_id": {
          "pattern": "^[a-z0-9][a-z0-9._-]{0,79}$",
          "title": "Check Id",
          "type": "string"
        },
        "duration_ms": {
          "minimum": 0,
          "title": "Duration Ms",
          "type": "integer"
        },
        "executable_name": {
          "maxLength": 160,
          "minLength": 1,
          "title": "Executable Name",
          "type": "string"
        },
        "executed_at": {
          "anyOf": [
            {
              "maxLength": 64,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Executed At"
        },
        "exit_code": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "title": "Exit Code"
        },
        "required": {
          "const": true,
          "title": "Required",
          "type": "boolean"
        },
        "status": {
          "enum": [
            "passed",
            "failed",
            "not_run",
            "error",
            "timeout"
          ],
          "title": "Status",
          "type": "string"
        },
        "stderr_bytes": {
          "minimum": 0,
          "title": "Stderr Bytes",
          "type": "integer"
        },
        "stderr_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Stderr Sha256",
          "type": "string"
        },
        "stdout_bytes": {
          "minimum": 0,
          "title": "Stdout Bytes",
          "type": "integer"
        },
        "stdout_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Stdout Sha256",
          "type": "string"
        }
      },
      "required": [
        "check_id",
        "status",
        "required",
        "argv_digest_sha256",
        "executable_name",
        "exit_code",
        "duration_ms",
        "stdout_sha256",
        "stdout_bytes",
        "stderr_sha256",
        "stderr_bytes"
      ],
      "title": "PersonalCheckResultV1",
      "type": "object"
    },
    "PrivacyBoundaryV1": {
      "additionalProperties": false,
      "properties": {
        "attention_stream_included": {
          "const": false,
          "title": "Attention Stream Included",
          "type": "boolean"
        },
        "automatic_customer_send_performed": {
          "const": false,
          "title": "Automatic Customer Send Performed",
          "type": "boolean"
        },
        "cookies_or_bearer_tokens_included": {
          "const": false,
          "title": "Cookies Or Bearer Tokens Included",
          "type": "boolean"
        },
        "metadata_only": {
          "const": true,
          "title": "Metadata Only",
          "type": "boolean"
        },
        "model_credentials_included": {
          "const": false,
          "title": "Model Credentials Included",
          "type": "boolean"
        },
        "model_prompts_included": {
          "const": false,
          "title": "Model Prompts Included",
          "type": "boolean"
        },
        "production_mutation_performed": {
          "const": false,
          "title": "Production Mutation Performed",
          "type": "boolean"
        },
        "raw_customer_payload_included": {
          "const": false,
          "title": "Raw Customer Payload Included",
          "type": "boolean"
        },
        "raw_report_text_included": {
          "const": false,
          "title": "Raw Report Text Included",
          "type": "boolean"
        },
        "raw_source_text_included": {
          "const": false,
          "title": "Raw Source Text Included",
          "type": "boolean"
        },
        "signed_urls_included": {
          "const": false,
          "title": "Signed Urls Included",
          "type": "boolean"
        }
      },
      "required": [
        "metadata_only",
        "raw_source_text_included",
        "raw_report_text_included",
        "raw_customer_payload_included",
        "attention_stream_included",
        "model_prompts_included",
        "model_credentials_included",
        "cookies_or_bearer_tokens_included",
        "signed_urls_included",
        "production_mutation_performed",
        "automatic_customer_send_performed"
      ],
      "title": "PrivacyBoundaryV1",
      "type": "object"
    }
  },
  "$id": "delivery-clearance.personal-check-run.v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "after_subject_digest_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "After Subject Digest Sha256",
      "type": "string"
    },
    "all_required_checks_passed": {
      "title": "All Required Checks Passed",
      "type": "boolean"
    },
    "before_subject_digest_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Before Subject Digest Sha256",
      "type": "string"
    },
    "checks_requested": {
      "title": "Checks Requested",
      "type": "boolean"
    },
    "claim_boundary": {
      "$ref": "#/$defs/ClaimBoundaryV1"
    },
    "privacy": {
      "$ref": "#/$defs/PrivacyBoundaryV1"
    },
    "project_ref": {
      "maxLength": 160,
      "minLength": 1,
      "title": "Project Ref",
      "type": "string"
    },
    "project_state_mutated_during_checks": {
      "title": "Project State Mutated During Checks",
      "type": "boolean"
    },
    "results": {
      "items": {
        "$ref": "#/$defs/PersonalCheckResultV1"
      },
      "minItems": 1,
      "title": "Results",
      "type": "array"
    },
    "schema_version": {
      "const": "delivery-clearance.personal-check-run.v1",
      "title": "Schema Version",
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "project_ref",
    "checks_requested",
    "all_required_checks_passed",
    "project_state_mutated_during_checks",
    "before_subject_digest_sha256",
    "after_subject_digest_sha256",
    "results",
    "claim_boundary",
    "privacy"
  ],
  "title": "PersonalCheckRunV1",
  "type": "object"
}
