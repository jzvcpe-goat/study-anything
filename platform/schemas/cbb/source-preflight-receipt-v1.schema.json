{
  "$defs": {
    "BenchmarkSource": {
      "enum": [
        "swe-bench-live",
        "tua-bench",
        "tau-bench",
        "agentdojo"
      ],
      "title": "BenchmarkSource",
      "type": "string"
    },
    "PrivacyBoundaryV1": {
      "additionalProperties": false,
      "properties": {
        "attention_stream_included": {
          "const": false,
          "title": "Attention Stream Included",
          "type": "boolean"
        },
        "automatic_customer_send_performed": {
          "const": false,
          "title": "Automatic Customer Send Performed",
          "type": "boolean"
        },
        "cookies_or_bearer_tokens_included": {
          "const": false,
          "title": "Cookies Or Bearer Tokens Included",
          "type": "boolean"
        },
        "metadata_only": {
          "const": true,
          "title": "Metadata Only",
          "type": "boolean"
        },
        "model_credentials_included": {
          "const": false,
          "title": "Model Credentials Included",
          "type": "boolean"
        },
        "model_prompts_included": {
          "const": false,
          "title": "Model Prompts Included",
          "type": "boolean"
        },
        "production_mutation_performed": {
          "const": false,
          "title": "Production Mutation Performed",
          "type": "boolean"
        },
        "raw_customer_payload_included": {
          "const": false,
          "title": "Raw Customer Payload Included",
          "type": "boolean"
        },
        "raw_report_text_included": {
          "const": false,
          "title": "Raw Report Text Included",
          "type": "boolean"
        },
        "raw_source_text_included": {
          "const": false,
          "title": "Raw Source Text Included",
          "type": "boolean"
        },
        "signed_urls_included": {
          "const": false,
          "title": "Signed Urls Included",
          "type": "boolean"
        }
      },
      "required": [
        "metadata_only",
        "raw_source_text_included",
        "raw_report_text_included",
        "raw_customer_payload_included",
        "attention_stream_included",
        "model_prompts_included",
        "model_credentials_included",
        "cookies_or_bearer_tokens_included",
        "signed_urls_included",
        "production_mutation_performed",
        "automatic_customer_send_performed"
      ],
      "title": "PrivacyBoundaryV1",
      "type": "object"
    },
    "SourcePreflightCheckV1": {
      "additionalProperties": false,
      "properties": {
        "blocking": {
          "title": "Blocking",
          "type": "boolean"
        },
        "check_id": {
          "pattern": "^[a-z0-9][a-z0-9._:-]{0,159}$",
          "title": "Check Id",
          "type": "string"
        },
        "detail_code": {
          "pattern": "^[a-z0-9][a-z0-9._:-]{0,159}$",
          "title": "Detail Code",
          "type": "string"
        },
        "evidence_digest_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Evidence Digest Sha256",
          "type": "string"
        },
        "status": {
          "enum": [
            "passed",
            "warning",
            "blocked"
          ],
          "title": "Status",
          "type": "string"
        }
      },
      "required": [
        "check_id",
        "status",
        "blocking",
        "detail_code",
        "evidence_digest_sha256"
      ],
      "title": "SourcePreflightCheckV1",
      "type": "object"
    }
  },
  "$id": "",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "benchmark_id": {
      "$ref": "#/$defs/BenchmarkSource"
    },
    "blocker_codes": {
      "items": {
        "type": "string"
      },
      "maxItems": 30,
      "title": "Blocker Codes",
      "type": "array"
    },
    "checks": {
      "items": {
        "$ref": "#/$defs/SourcePreflightCheckV1"
      },
      "maxItems": 40,
      "minItems": 1,
      "title": "Checks",
      "type": "array"
    },
    "docker_cli_available": {
      "title": "Docker Cli Available",
      "type": "boolean"
    },
    "docker_daemon_available": {
      "title": "Docker Daemon Available",
      "type": "boolean"
    },
    "execution_readiness": {
      "enum": [
        "source_unavailable",
        "source_ready_execution_blocked",
        "execution_ready"
      ],
      "title": "Execution Readiness",
      "type": "string"
    },
    "expected_scorer_revision": {
      "pattern": "^[0-9a-f]{40,64}$",
      "title": "Expected Scorer Revision",
      "type": "string"
    },
    "expected_task_data_revision": {
      "pattern": "^[0-9a-f]{40,64}$",
      "title": "Expected Task Data Revision",
      "type": "string"
    },
    "generated_at": {
      "maxLength": 64,
      "minLength": 1,
      "title": "Generated At",
      "type": "string"
    },
    "license_id": {
      "enum": [
        "MIT",
        "CC-BY-NC-4.0"
      ],
      "title": "License Id",
      "type": "string"
    },
    "license_use_scope": {
      "enum": [
        "permissive",
        "personal_noncommercial"
      ],
      "title": "License Use Scope",
      "type": "string"
    },
    "local_absolute_paths_included": {
      "const": false,
      "default": false,
      "title": "Local Absolute Paths Included",
      "type": "boolean"
    },
    "memory_bytes": {
      "minimum": 0,
      "title": "Memory Bytes",
      "type": "integer"
    },
    "model_runtime_available": {
      "title": "Model Runtime Available",
      "type": "boolean"
    },
    "observed_adapter_available": {
      "title": "Observed Adapter Available",
      "type": "boolean"
    },
    "observed_scorer_revision": {
      "anyOf": [
        {
          "pattern": "^[0-9a-f]{40,64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Observed Scorer Revision"
    },
    "observed_task_data_revision": {
      "anyOf": [
        {
          "pattern": "^[0-9a-f]{40,64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Observed Task Data Revision"
    },
    "official_scorer_present": {
      "title": "Official Scorer Present",
      "type": "boolean"
    },
    "official_scorer_ref": {
      "maxLength": 1000,
      "minLength": 1,
      "title": "Official Scorer Ref",
      "type": "string"
    },
    "platform_architecture": {
      "enum": [
        "arm64",
        "x86_64",
        "other"
      ],
      "title": "Platform Architecture",
      "type": "string"
    },
    "privacy": {
      "$ref": "#/$defs/PrivacyBoundaryV1"
    },
    "raw_scorer_output_included": {
      "const": false,
      "default": false,
      "title": "Raw Scorer Output Included",
      "type": "boolean"
    },
    "raw_task_payload_included": {
      "const": false,
      "default": false,
      "title": "Raw Task Payload Included",
      "type": "boolean"
    },
    "receipt_id": {
      "pattern": "^[a-z0-9][a-z0-9._:-]{0,159}$",
      "title": "Receipt Id",
      "type": "string"
    },
    "schema_version": {
      "const": "source-preflight-receipt-v1",
      "title": "Schema Version",
      "type": "string"
    },
    "scorer_source_acquired": {
      "title": "Scorer Source Acquired",
      "type": "boolean"
    },
    "scorer_tree_digest_sha256": {
      "anyOf": [
        {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Scorer Tree Digest Sha256"
    },
    "selected_task_count": {
      "maximum": 1000,
      "minimum": 1,
      "title": "Selected Task Count",
      "type": "integer"
    },
    "selected_task_identities_verified": {
      "title": "Selected Task Identities Verified",
      "type": "boolean"
    },
    "selected_task_identity_digest_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Selected Task Identity Digest Sha256",
      "type": "string"
    },
    "suite_id": {
      "pattern": "^[a-z0-9][a-z0-9._:-]{0,159}$",
      "title": "Suite Id",
      "type": "string"
    },
    "task_data_acquired": {
      "title": "Task Data Acquired",
      "type": "boolean"
    },
    "task_data_digest_sha256": {
      "anyOf": [
        {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Task Data Digest Sha256"
    },
    "third_party_asset_terms_reviewed": {
      "title": "Third Party Asset Terms Reviewed",
      "type": "boolean"
    },
    "uv_available": {
      "title": "Uv Available",
      "type": "boolean"
    },
    "warning_codes": {
      "items": {
        "type": "string"
      },
      "maxItems": 30,
      "title": "Warning Codes",
      "type": "array"
    }
  },
  "required": [
    "schema_version",
    "receipt_id",
    "suite_id",
    "benchmark_id",
    "expected_task_data_revision",
    "expected_scorer_revision",
    "selected_task_count",
    "selected_task_identity_digest_sha256",
    "selected_task_identities_verified",
    "official_scorer_ref",
    "official_scorer_present",
    "task_data_acquired",
    "scorer_source_acquired",
    "license_id",
    "license_use_scope",
    "third_party_asset_terms_reviewed",
    "platform_architecture",
    "memory_bytes",
    "docker_cli_available",
    "docker_daemon_available",
    "uv_available",
    "model_runtime_available",
    "observed_adapter_available",
    "execution_readiness",
    "blocker_codes",
    "warning_codes",
    "checks",
    "generated_at",
    "privacy"
  ],
  "title": "SourcePreflightReceiptV1",
  "type": "object"
}
