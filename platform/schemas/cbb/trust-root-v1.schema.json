{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "trust-root-v1",
  "title": "CBB Trust Root v1",
  "type": "object",
  "required": [
    "schema_version",
    "trust_root_id",
    "project_id",
    "accepted_evidence",
    "forbidden_trust_bases",
    "kernel",
    "isolation",
    "privacy"
  ],
  "properties": {
    "schema_version": {
      "const": "trust-root-v1"
    },
    "accepted_evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "forbidden_trust_bases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "kernel": {
      "type": "object",
      "required": [
        "deterministic",
        "model_calls_allowed",
        "production_mutation_allowed",
        "raw_payload_access_allowed"
      ],
      "properties": {
        "deterministic": {
          "const": true
        },
        "model_calls_allowed": {
          "const": false
        },
        "production_mutation_allowed": {
          "const": false
        },
        "raw_payload_access_allowed": {
          "const": false
        }
      }
    }
  }
}
