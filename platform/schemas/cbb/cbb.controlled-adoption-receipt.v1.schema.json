{
  "$defs": {
    "AdoptionBindingV1": {
      "additionalProperties": false,
      "properties": {
        "conformance_pack_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Conformance Pack Sha256",
          "type": "string"
        },
        "protocol_version": {
          "const": "1.0.0",
          "title": "Protocol Version",
          "type": "string"
        },
        "release_scope_commit": {
          "pattern": "^[0-9a-f]{40}$",
          "title": "Release Scope Commit",
          "type": "string"
        },
        "source_approved_scope": {
          "$ref": "#/$defs/DeliveryScope"
        },
        "source_clearance_revocation_handle": {
          "maxLength": 200,
          "minLength": 1,
          "title": "Source Clearance Revocation Handle",
          "type": "string"
        },
        "source_delivery_receipt_ref": {
          "maxLength": 500,
          "minLength": 1,
          "title": "Source Delivery Receipt Ref",
          "type": "string"
        },
        "source_package_digest_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Source Package Digest Sha256",
          "type": "string"
        },
        "source_package_ref": {
          "maxLength": 500,
          "minLength": 1,
          "title": "Source Package Ref",
          "type": "string"
        }
      },
      "required": [
        "release_scope_commit",
        "protocol_version",
        "source_package_ref",
        "source_package_digest_sha256",
        "source_delivery_receipt_ref",
        "source_clearance_revocation_handle",
        "source_approved_scope",
        "conformance_pack_sha256"
      ],
      "title": "AdoptionBindingV1",
      "type": "object"
    },
    "AdoptionEvidenceClass": {
      "enum": [
        "synthetic_fixture",
        "local_shadow",
        "local_dogfood",
        "external_adopter"
      ],
      "title": "AdoptionEvidenceClass",
      "type": "string"
    },
    "AdoptionMode": {
      "enum": [
        "shadow",
        "dogfood",
        "canary"
      ],
      "title": "AdoptionMode",
      "type": "string"
    },
    "AdoptionObservationKind": {
      "enum": [
        "pass",
        "block",
        "incident",
        "rollback",
        "revocation",
        "reopen"
      ],
      "title": "AdoptionObservationKind",
      "type": "string"
    },
    "ClaimBoundaryV1": {
      "additionalProperties": false,
      "properties": {
        "current_claim": {
          "maxLength": 2000,
          "minLength": 1,
          "title": "Current Claim",
          "type": "string"
        },
        "maximum_scope": {
          "$ref": "#/$defs/DeliveryScope"
        },
        "not_claimed": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Not Claimed",
          "type": "array"
        }
      },
      "required": [
        "current_claim",
        "maximum_scope",
        "not_claimed"
      ],
      "title": "ClaimBoundaryV1",
      "type": "object"
    },
    "ControlledAdoptionStatus": {
      "enum": [
        "observed",
        "blocked",
        "incident_recorded",
        "rolled_back",
        "revoked",
        "reopen_required"
      ],
      "title": "ControlledAdoptionStatus",
      "type": "string"
    },
    "DeliveryScope": {
      "description": "Ordered scopes from no release authority to a production candidate.",
      "enum": [
        "blocked",
        "personal_local",
        "sandbox_only",
        "public_demo",
        "internal_handoff",
        "controlled_customer_handoff",
        "limited_beta",
        "production_candidate"
      ],
      "title": "DeliveryScope",
      "type": "string"
    },
    "PrivacyBoundaryV1": {
      "additionalProperties": false,
      "properties": {
        "attention_stream_included": {
          "const": false,
          "title": "Attention Stream Included",
          "type": "boolean"
        },
        "automatic_customer_send_performed": {
          "const": false,
          "title": "Automatic Customer Send Performed",
          "type": "boolean"
        },
        "cookies_or_bearer_tokens_included": {
          "const": false,
          "title": "Cookies Or Bearer Tokens Included",
          "type": "boolean"
        },
        "metadata_only": {
          "const": true,
          "title": "Metadata Only",
          "type": "boolean"
        },
        "model_credentials_included": {
          "const": false,
          "title": "Model Credentials Included",
          "type": "boolean"
        },
        "model_prompts_included": {
          "const": false,
          "title": "Model Prompts Included",
          "type": "boolean"
        },
        "production_mutation_performed": {
          "const": false,
          "title": "Production Mutation Performed",
          "type": "boolean"
        },
        "raw_customer_payload_included": {
          "const": false,
          "title": "Raw Customer Payload Included",
          "type": "boolean"
        },
        "raw_report_text_included": {
          "const": false,
          "title": "Raw Report Text Included",
          "type": "boolean"
        },
        "raw_source_text_included": {
          "const": false,
          "title": "Raw Source Text Included",
          "type": "boolean"
        },
        "signed_urls_included": {
          "const": false,
          "title": "Signed Urls Included",
          "type": "boolean"
        }
      },
      "required": [
        "metadata_only",
        "raw_source_text_included",
        "raw_report_text_included",
        "raw_customer_payload_included",
        "attention_stream_included",
        "model_prompts_included",
        "model_credentials_included",
        "cookies_or_bearer_tokens_included",
        "signed_urls_included",
        "production_mutation_performed",
        "automatic_customer_send_performed"
      ],
      "title": "PrivacyBoundaryV1",
      "type": "object"
    }
  },
  "$id": "cbb.controlled-adoption-receipt.v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "adoption_mode": {
      "$ref": "#/$defs/AdoptionMode"
    },
    "audit_completed": {
      "const": false,
      "title": "Audit Completed",
      "type": "boolean"
    },
    "authorization_delta": {
      "enum": [
        "none",
        "narrowed",
        "blocked"
      ],
      "title": "Authorization Delta",
      "type": "string"
    },
    "binding": {
      "$ref": "#/$defs/AdoptionBindingV1"
    },
    "case_id": {
      "maxLength": 160,
      "minLength": 1,
      "title": "Case Id",
      "type": "string"
    },
    "checks": {
      "additionalProperties": {
        "type": "boolean"
      },
      "minProperties": 1,
      "title": "Checks",
      "type": "object"
    },
    "claim_boundary": {
      "$ref": "#/$defs/ClaimBoundaryV1"
    },
    "customer_delivery_authorized": {
      "const": false,
      "title": "Customer Delivery Authorized",
      "type": "boolean"
    },
    "evidence_class": {
      "$ref": "#/$defs/AdoptionEvidenceClass"
    },
    "external_attestation_receipt_ref": {
      "anyOf": [
        {
          "maxLength": 500,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "External Attestation Receipt Ref"
    },
    "external_attestation_receipt_sha256": {
      "anyOf": [
        {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "External Attestation Receipt Sha256"
    },
    "observation_kind": {
      "$ref": "#/$defs/AdoptionObservationKind"
    },
    "observed_at": {
      "maxLength": 64,
      "minLength": 1,
      "title": "Observed At",
      "type": "string"
    },
    "outcome_receipt_ref": {
      "anyOf": [
        {
          "maxLength": 500,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Outcome Receipt Ref"
    },
    "outcome_status": {
      "anyOf": [
        {
          "enum": [
            "monitored",
            "degraded",
            "frozen",
            "revoked"
          ],
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "title": "Outcome Status"
    },
    "privacy": {
      "$ref": "#/$defs/PrivacyBoundaryV1"
    },
    "production_authorized": {
      "const": false,
      "title": "Production Authorized",
      "type": "boolean"
    },
    "real_adopter_evidence": {
      "title": "Real Adopter Evidence",
      "type": "boolean"
    },
    "reasons": {
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "title": "Reasons",
      "type": "array"
    },
    "receipt_id": {
      "maxLength": 200,
      "minLength": 1,
      "title": "Receipt Id",
      "type": "string"
    },
    "requested_scope": {
      "$ref": "#/$defs/DeliveryScope"
    },
    "resulting_scope": {
      "$ref": "#/$defs/DeliveryScope"
    },
    "schema_version": {
      "const": "cbb.controlled-adoption-receipt.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "status": {
      "$ref": "#/$defs/ControlledAdoptionStatus"
    },
    "trust_action": {
      "anyOf": [
        {
          "maxLength": 120,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Trust Action"
    }
  },
  "required": [
    "schema_version",
    "receipt_id",
    "case_id",
    "evidence_class",
    "adoption_mode",
    "observation_kind",
    "status",
    "binding",
    "requested_scope",
    "resulting_scope",
    "outcome_status",
    "authorization_delta",
    "checks",
    "reasons",
    "real_adopter_evidence",
    "customer_delivery_authorized",
    "production_authorized",
    "audit_completed",
    "claim_boundary",
    "privacy",
    "observed_at"
  ],
  "title": "ControlledAdoptionReceiptV1",
  "type": "object"
}
