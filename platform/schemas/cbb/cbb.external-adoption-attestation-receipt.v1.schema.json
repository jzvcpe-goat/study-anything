{
  "$defs": {
    "AdoptionAttestationSourceClass": {
      "enum": [
        "synthetic_fixture",
        "external_shape_fixture",
        "external_attestation"
      ],
      "title": "AdoptionAttestationSourceClass",
      "type": "string"
    },
    "AdoptionAttestationState": {
      "enum": [
        "attestation_ready",
        "rejected",
        "synthetic_validated",
        "external_attestation_verified"
      ],
      "title": "AdoptionAttestationState",
      "type": "string"
    },
    "ClaimBoundaryV1": {
      "additionalProperties": false,
      "properties": {
        "current_claim": {
          "maxLength": 2000,
          "minLength": 1,
          "title": "Current Claim",
          "type": "string"
        },
        "maximum_scope": {
          "$ref": "#/$defs/DeliveryScope"
        },
        "not_claimed": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "title": "Not Claimed",
          "type": "array"
        }
      },
      "required": [
        "current_claim",
        "maximum_scope",
        "not_claimed"
      ],
      "title": "ClaimBoundaryV1",
      "type": "object"
    },
    "DeliveryScope": {
      "description": "Ordered scopes from no release authority to a production candidate.",
      "enum": [
        "blocked",
        "personal_local",
        "sandbox_only",
        "public_demo",
        "internal_handoff",
        "controlled_customer_handoff",
        "limited_beta",
        "production_candidate"
      ],
      "title": "DeliveryScope",
      "type": "string"
    },
    "ExternalAdoptionAttestationBindingV1": {
      "additionalProperties": false,
      "properties": {
        "adoption_case_id": {
          "maxLength": 160,
          "minLength": 1,
          "title": "Adoption Case Id",
          "type": "string"
        },
        "adoption_case_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Adoption Case Sha256",
          "type": "string"
        },
        "conformance_pack_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Conformance Pack Sha256",
          "type": "string"
        },
        "protocol_version": {
          "const": "1.0.0",
          "title": "Protocol Version",
          "type": "string"
        },
        "release_scope_commit": {
          "pattern": "^[0-9a-f]{40}$",
          "title": "Release Scope Commit",
          "type": "string"
        },
        "repository": {
          "const": "jzvcpe-goat/study-anything",
          "title": "Repository",
          "type": "string"
        },
        "source_approved_scope": {
          "$ref": "#/$defs/DeliveryScope"
        },
        "source_clearance_revocation_handle": {
          "maxLength": 200,
          "minLength": 1,
          "title": "Source Clearance Revocation Handle",
          "type": "string"
        },
        "source_delivery_receipt_ref": {
          "maxLength": 500,
          "minLength": 1,
          "title": "Source Delivery Receipt Ref",
          "type": "string"
        },
        "source_package_digest_sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "title": "Source Package Digest Sha256",
          "type": "string"
        }
      },
      "required": [
        "repository",
        "release_scope_commit",
        "protocol_version",
        "conformance_pack_sha256",
        "source_package_digest_sha256",
        "source_delivery_receipt_ref",
        "source_clearance_revocation_handle",
        "source_approved_scope",
        "adoption_case_id",
        "adoption_case_sha256"
      ],
      "title": "ExternalAdoptionAttestationBindingV1",
      "type": "object"
    },
    "PrivacyBoundaryV1": {
      "additionalProperties": false,
      "properties": {
        "attention_stream_included": {
          "const": false,
          "title": "Attention Stream Included",
          "type": "boolean"
        },
        "automatic_customer_send_performed": {
          "const": false,
          "title": "Automatic Customer Send Performed",
          "type": "boolean"
        },
        "cookies_or_bearer_tokens_included": {
          "const": false,
          "title": "Cookies Or Bearer Tokens Included",
          "type": "boolean"
        },
        "metadata_only": {
          "const": true,
          "title": "Metadata Only",
          "type": "boolean"
        },
        "model_credentials_included": {
          "const": false,
          "title": "Model Credentials Included",
          "type": "boolean"
        },
        "model_prompts_included": {
          "const": false,
          "title": "Model Prompts Included",
          "type": "boolean"
        },
        "production_mutation_performed": {
          "const": false,
          "title": "Production Mutation Performed",
          "type": "boolean"
        },
        "raw_customer_payload_included": {
          "const": false,
          "title": "Raw Customer Payload Included",
          "type": "boolean"
        },
        "raw_report_text_included": {
          "const": false,
          "title": "Raw Report Text Included",
          "type": "boolean"
        },
        "raw_source_text_included": {
          "const": false,
          "title": "Raw Source Text Included",
          "type": "boolean"
        },
        "signed_urls_included": {
          "const": false,
          "title": "Signed Urls Included",
          "type": "boolean"
        }
      },
      "required": [
        "metadata_only",
        "raw_source_text_included",
        "raw_report_text_included",
        "raw_customer_payload_included",
        "attention_stream_included",
        "model_prompts_included",
        "model_credentials_included",
        "cookies_or_bearer_tokens_included",
        "signed_urls_included",
        "production_mutation_performed",
        "automatic_customer_send_performed"
      ],
      "title": "PrivacyBoundaryV1",
      "type": "object"
    }
  },
  "$id": "cbb.external-adoption-attestation-receipt.v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "attestation_digest_sha256": {
      "anyOf": [
        {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Attestation Digest Sha256"
    },
    "audit_completed": {
      "const": false,
      "title": "Audit Completed",
      "type": "boolean"
    },
    "binding": {
      "$ref": "#/$defs/ExternalAdoptionAttestationBindingV1"
    },
    "blocking_reasons": {
      "items": {
        "type": "string"
      },
      "title": "Blocking Reasons",
      "type": "array"
    },
    "checks": {
      "additionalProperties": {
        "type": "boolean"
      },
      "minProperties": 1,
      "title": "Checks",
      "type": "object"
    },
    "claim_boundary": {
      "$ref": "#/$defs/ClaimBoundaryV1"
    },
    "delivery_authority_granted": {
      "const": false,
      "title": "Delivery Authority Granted",
      "type": "boolean"
    },
    "evaluated_at": {
      "maxLength": 64,
      "minLength": 1,
      "title": "Evaluated At",
      "type": "string"
    },
    "external_identity_attested": {
      "title": "External Identity Attested",
      "type": "boolean"
    },
    "next_required_actions": {
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "title": "Next Required Actions",
      "type": "array"
    },
    "observation_execution_completed": {
      "title": "Observation Execution Completed",
      "type": "boolean"
    },
    "privacy": {
      "$ref": "#/$defs/PrivacyBoundaryV1"
    },
    "production_authority_granted": {
      "const": false,
      "title": "Production Authority Granted",
      "type": "boolean"
    },
    "real_adopter_evidence_accepted": {
      "title": "Real Adopter Evidence Accepted",
      "type": "boolean"
    },
    "receipt_id": {
      "maxLength": 200,
      "minLength": 1,
      "title": "Receipt Id",
      "type": "string"
    },
    "schema_version": {
      "const": "cbb.external-adoption-attestation-receipt.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "signature_verified": {
      "title": "Signature Verified",
      "type": "boolean"
    },
    "source_class": {
      "anyOf": [
        {
          "$ref": "#/$defs/AdoptionAttestationSourceClass"
        },
        {
          "type": "null"
        }
      ]
    },
    "state": {
      "$ref": "#/$defs/AdoptionAttestationState"
    }
  },
  "required": [
    "schema_version",
    "receipt_id",
    "state",
    "source_class",
    "binding",
    "signature_verified",
    "external_identity_attested",
    "observation_execution_completed",
    "real_adopter_evidence_accepted",
    "checks",
    "blocking_reasons",
    "next_required_actions",
    "delivery_authority_granted",
    "production_authority_granted",
    "audit_completed",
    "claim_boundary",
    "privacy",
    "evaluated_at"
  ],
  "title": "ExternalAdoptionAttestationReceiptV1",
  "type": "object"
}
