{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "patch-proposal-product-spec-eval-candidate-v1",
  "title": "Patch Proposal Product Spec Eval Candidate",
  "type": "object",
  "required": [
    "schema_version",
    "candidate_id",
    "source_backlog_signal_id",
    "source_backlog_signal_hash",
    "source_feedback_intake_id",
    "source_feedback_intake_hash",
    "source_delivery_class",
    "feedback_ref",
    "loop",
    "destination",
    "next_boundary",
    "priority_state",
    "priority_score_included",
    "requires_product_owner_prioritization_before_execution",
    "ready_for_execution",
    "ready_for_delivery_trust_harness",
    "blocked_destinations",
    "effect_boundary",
    "claim_boundary",
    "privacy",
    "isolation"
  ],
  "properties": {
    "schema_version": {
      "const": "patch-proposal-product-spec-eval-candidate-v1"
    },
    "candidate_id": {
      "type": "string"
    },
    "source_backlog_signal_id": {
      "type": "string"
    },
    "source_backlog_signal_hash": {
      "type": "string"
    },
    "source_feedback_intake_id": {
      "type": "string"
    },
    "source_feedback_intake_hash": {
      "type": "string"
    },
    "source_delivery_class": {
      "const": "patch-proposal"
    },
    "feedback_ref": {
      "type": "object"
    },
    "loop": {
      "const": "developer_feedback_loop"
    },
    "destination": {
      "const": "product_spec_eval_candidate_queue"
    },
    "next_boundary": {
      "const": "product_spec_eval_authoring"
    },
    "priority_state": {
      "const": "unassigned"
    },
    "priority_score_included": {
      "const": false
    },
    "requires_product_owner_prioritization_before_execution": {
      "const": true
    },
    "ready_for_execution": {
      "const": false
    },
    "ready_for_delivery_trust_harness": {
      "const": false
    },
    "blocked_destinations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "effect_boundary": {
      "type": "object"
    },
    "claim_boundary": {
      "type": "object"
    },
    "privacy": {
      "type": "object"
    },
    "isolation": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
