{
  "$defs": {
    "PersonalCheckConfigV1": {
      "additionalProperties": false,
      "properties": {
        "argv": {
          "items": {
            "type": "string"
          },
          "maxItems": 32,
          "minItems": 1,
          "title": "Argv",
          "type": "array"
        },
        "check_id": {
          "pattern": "^[a-z0-9][a-z0-9._-]{0,79}$",
          "title": "Check Id",
          "type": "string"
        },
        "required": {
          "const": true,
          "default": true,
          "title": "Required",
          "type": "boolean"
        },
        "timeout_seconds": {
          "default": 300,
          "maximum": 3600,
          "minimum": 1,
          "title": "Timeout Seconds",
          "type": "integer"
        }
      },
      "required": [
        "check_id",
        "argv"
      ],
      "title": "PersonalCheckConfigV1",
      "type": "object"
    },
    "PersonalHardBoundariesV1": {
      "additionalProperties": false,
      "properties": {
        "external_delivery_allowed": {
          "const": false,
          "default": false,
          "title": "External Delivery Allowed",
          "type": "boolean"
        },
        "irreversible_effects_allowed": {
          "const": false,
          "default": false,
          "title": "Irreversible Effects Allowed",
          "type": "boolean"
        },
        "production_mutation_allowed": {
          "const": false,
          "default": false,
          "title": "Production Mutation Allowed",
          "type": "boolean"
        }
      },
      "title": "PersonalHardBoundariesV1",
      "type": "object"
    }
  },
  "$id": "delivery-clearance.personal-config.v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "checks": {
      "items": {
        "$ref": "#/$defs/PersonalCheckConfigV1"
      },
      "maxItems": 20,
      "minItems": 1,
      "title": "Checks",
      "type": "array"
    },
    "critical_failure_path": {
      "maxLength": 2000,
      "minLength": 1,
      "title": "Critical Failure Path",
      "type": "string"
    },
    "evidence_limitations": {
      "items": {
        "type": "string"
      },
      "maxItems": 20,
      "minItems": 1,
      "title": "Evidence Limitations",
      "type": "array"
    },
    "hard_boundaries": {
      "$ref": "#/$defs/PersonalHardBoundariesV1"
    },
    "maximum_scope": {
      "const": "personal_local",
      "default": "personal_local",
      "title": "Maximum Scope",
      "type": "string"
    },
    "non_goals": {
      "items": {
        "type": "string"
      },
      "maxItems": 20,
      "minItems": 1,
      "title": "Non Goals",
      "type": "array"
    },
    "project_id": {
      "maxLength": 160,
      "minLength": 1,
      "title": "Project Id",
      "type": "string"
    },
    "purpose": {
      "maxLength": 1000,
      "minLength": 1,
      "title": "Purpose",
      "type": "string"
    },
    "recipient_kind": {
      "const": "self",
      "default": "self",
      "title": "Recipient Kind",
      "type": "string"
    },
    "rollback_strategy": {
      "maxLength": 2000,
      "minLength": 1,
      "title": "Rollback Strategy",
      "type": "string"
    },
    "rollback_trigger": {
      "maxLength": 1000,
      "minLength": 1,
      "title": "Rollback Trigger",
      "type": "string"
    },
    "schema_version": {
      "const": "delivery-clearance.personal-config.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "validity_hours": {
      "default": 24,
      "maximum": 168,
      "minimum": 1,
      "title": "Validity Hours",
      "type": "integer"
    }
  },
  "required": [
    "schema_version",
    "project_id",
    "purpose",
    "non_goals",
    "critical_failure_path",
    "rollback_trigger",
    "rollback_strategy",
    "evidence_limitations",
    "hard_boundaries",
    "checks"
  ],
  "title": "PersonalClearanceConfigV1",
  "type": "object"
}
