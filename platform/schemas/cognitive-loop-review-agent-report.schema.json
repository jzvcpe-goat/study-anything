{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://study-anything.local/schemas/cognitive-loop-review-agent-report-v1.json",
  "title": "Cognitive Loop Review Agent final report",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "report_version",
    "pr_id",
    "change_type",
    "overall_risk",
    "decision",
    "summary",
    "findings",
    "metrics",
    "ci_instructions",
    "suppressed_low_confidence"
  ],
  "properties": {
    "report_version": {
      "const": "1.0"
    },
    "pr_id": {
      "type": "string",
      "minLength": 1
    },
    "change_type": {
      "type": "string",
      "enum": [
        "bugfix",
        "feature",
        "refactor",
        "config",
        "docs",
        "test",
        "mixed"
      ]
    },
    "overall_risk": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "decision": {
      "type": "string",
      "enum": [
        "approved",
        "needs-review",
        "needs-fix"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 600
    },
    "findings": {
      "type": "array",
      "maxItems": 8,
      "items": {
        "$ref": "#/$defs/finding"
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "total_files_changed",
        "total_lines_changed",
        "critical_count",
        "warn_count",
        "info_count",
        "review_dimensions_covered"
      ],
      "properties": {
        "total_files_changed": {
          "type": "integer",
          "minimum": 0
        },
        "total_lines_changed": {
          "type": "integer",
          "minimum": 0
        },
        "critical_count": {
          "type": "integer",
          "minimum": 0
        },
        "warn_count": {
          "type": "integer",
          "minimum": 0
        },
        "info_count": {
          "type": "integer",
          "minimum": 0
        },
        "review_dimensions_covered": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "logic",
              "security",
              "architecture",
              "test"
            ]
          }
        }
      }
    },
    "ci_instructions": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "should_block_merge",
        "required_human_review",
        "labels_to_add"
      ],
      "properties": {
        "should_block_merge": {
          "type": "boolean"
        },
        "required_human_review": {
          "type": "boolean"
        },
        "labels_to_add": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "suppressed_low_confidence": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/suppressedFinding"
      }
    }
  },
  "$defs": {
    "finding": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "rank",
        "dimension",
        "title",
        "severity",
        "file",
        "line_range",
        "evidence",
        "recommendation",
        "confidence",
        "blocking"
      ],
      "properties": {
        "rank": {
          "type": "integer",
          "minimum": 1,
          "maximum": 8
        },
        "dimension": {
          "type": "string",
          "enum": [
            "logic",
            "security",
            "architecture",
            "test"
          ]
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "severity": {
          "type": "string",
          "enum": [
            "info",
            "warn",
            "critical"
          ]
        },
        "file": {
          "type": "string",
          "minLength": 1
        },
        "line_range": {
          "type": "string",
          "pattern": "^[0-9]+(-[0-9]+)?$"
        },
        "evidence": {
          "type": "string",
          "minLength": 8
        },
        "recommendation": {
          "type": "string",
          "minLength": 1
        },
        "confidence": {
          "type": "string",
          "enum": [
            "medium",
            "high"
          ]
        },
        "blocking": {
          "type": "boolean"
        },
        "cwe_references": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^CWE-[0-9]+$"
          }
        }
      }
    },
    "suppressedFinding": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "dimension",
        "title",
        "file",
        "line_range",
        "evidence",
        "confidence",
        "suppression_reason"
      ],
      "properties": {
        "dimension": {
          "type": "string",
          "enum": [
            "logic",
            "security",
            "architecture",
            "test"
          ]
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "file": {
          "type": "string",
          "minLength": 1
        },
        "line_range": {
          "type": "string",
          "pattern": "^[0-9]+(-[0-9]+)?$"
        },
        "evidence": {
          "type": "string",
          "minLength": 8
        },
        "confidence": {
          "const": "low"
        },
        "suppression_reason": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
